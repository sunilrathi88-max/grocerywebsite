  "freshness_scoring_algorithm": {
    "base_score": 100,
    "factors": {
      "age_penalty": {
        "description": "Spice degradation over time",
        "calculation": "(age_in_months / shelf_life_months) * 30",
        "max_penalty": 30
      },
      "visual_quality": {
        "description": "Color vibrancy assessment (1-5 slider)",
        "calculation": "(5 - visual_score) * 10",
        "max_penalty": 40,
        "notes": "1=very faded, 5=vibrant and fresh"
      },
      "aromatic_quality": {
        "description": "Aroma strength assessment (1-5 slider)",
        "calculation": "(5 - aroma_score) * 15",
        "max_penalty": 60,
        "notes": "1=no aroma, 5=strong distinctive aroma"
      },
      "storage_method_bonus": {
        "description": "Positive adjustment based on storage conditions",
        "options": {
          "freezer": 15,
          "airtight_container": 10,
          "fridge": 8,
          "normal_shelf": 0,
          "open_container": -5
        }
      }
    },
    "final_calculation": "max(0, min(100, base_score - age_penalty - visual_penalty - aroma_penalty + storage_bonus))",
    "score_interpretation": {
      "80_100": {
        "status": "Excellent",
        "emoji": "✅",
        "recommendation": "Use immediately. Peak flavor and aroma.",
        "shelf_life_remaining": "6+ months"
      },
      "60_79": {
        "status": "Good",
        "emoji": "👍",
        "recommendation": "Good to use. Consider replacing within 1-2 months.",
        "shelf_life_remaining": "3-6 months"
      },
      "40_59": {
        "status": "Fair",
        "emoji": "⚠️",
        "recommendation": "Still usable but losing quality. Replace soon.",
        "shelf_life_remaining": "1-3 months"
      },
      "20_39": {
        "status": "Poor",
        "emoji": "❌",
        "recommendation": "Consider replacing. Flavor compromised.",
        "shelf_life_remaining": "Less than 1 month"
      },
      "0_19": {
        "status": "Expired",
        "emoji": "🚫",
        "recommendation": "Replace immediately. Health/safety risk.",
        "shelf_life_remaining": "Expired"
      }
    }
  },
